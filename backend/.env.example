# Backend env vars. Copy to backend/.env and fill in.
# These NEVER ship to the frontend — keep this file out of git.

# Supabase --------------------------------------------------------
# From Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# anon key is used only as a fallback; backend mainly uses the service role
SUPABASE_ANON_KEY=eyJhbGciOi...
# Service-role key (DANGEROUS — bypasses RLS). Backend-only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# JWT secret — LEGACY FALLBACK ONLY (Phase 8A).
# New Supabase projects sign tokens asymmetrically; the backend verifies them
# automatically via JWKS at <SUPABASE_URL>/auth/v1/.well-known/jwks.json.
# Leave blank for new projects; set it only if your project still uses HS256.
SUPABASE_JWT_SECRET=

# Anthropic (used from Phase 5 onward) ----------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_HEAVY_MODEL=claude-opus-4-7
DB_ENCRYPTION_KEY=<the value you just generated>
# App -------------------------------------------------------------
# Comma-separated origins the FastAPI CORS layer will allow.
CORS_ORIGINS=http://localhost:3000
# Cap raw uploads we'll process (bytes). 200 MB by default.
MAX_UPLOAD_BYTES=209715200


GEMINI_API_KEY=AIza...your key...
GEMINI_MODEL=gemini-2.5-flash
